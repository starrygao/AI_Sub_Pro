{
  "name": "ai-sub-pro",
  "version": "1.1.0",
  "scripts": {
    "build:css": "npx --yes tailwindcss@3.4.17 -c tailwind.config.js -i app/static/css/tailwind.input.css -o app/static/css/tailwind.css --minify",
    "dev": "cd electron && npx electron .",
    "start": "python3 app/main.py",
    "build-mac": "cd electron && npm run build-mac",
    "build-win": "cd electron && npm run build-win"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
