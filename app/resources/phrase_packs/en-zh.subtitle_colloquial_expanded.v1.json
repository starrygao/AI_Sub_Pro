      "quality": 0.84,
      "tags": [
        "dialogue"
      ]
    },
    {
      "source_text": "This is not up for debate.",
      "target_text": "这事没得商量。",
      "quality": 0.84,
      "tags": [
        "conflict"
      ]
    },
    {
      "source_text": "You owe me an explanation.",
      "target_text": "你得给我个解释。",
      "quality": 0.84,
      "tags": [
        "conflict"
      ]
    },
    {
      "source_text": "Don't make me regret this.",
      "target_text": "别让我后悔帮你。",
      "quality": 0.84,
      "tags": [
        "dialogue"
      ]
    },
    {
      "source_text": "I need you to trust me.",
