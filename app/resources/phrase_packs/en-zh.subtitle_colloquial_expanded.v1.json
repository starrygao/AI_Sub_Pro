      "quality": 0.84,
      "tags": [
        "reaction"
      ]
    },
    {
      "source_text": "I am so done with this.",
      "target_text": "我真的受够了。",
      "quality": 0.84,
      "tags": [
        "subtitle",
        "colloquial"
      ]
    },
    {
      "source_text": "I am way out of my depth.",
