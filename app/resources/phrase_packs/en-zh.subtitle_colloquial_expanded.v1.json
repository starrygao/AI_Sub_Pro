    },
    {
      "source_text": "I am trying to be reasonable.",
      "target_text": "我已经在尽量讲道理了。",
      "quality": 0.84,
      "tags": [
        "subtitle",
        "colloquial"
      ]
    },
    {
      "source_text": "You are not listening.",
      "target_text": "你根本没在听。",
      "quality": 0.84,
      "tags": [
        "subtitle",
        "colloquial"
      ]
    },
    {
      "source_text": "You are making this worse.",
