      "target_text": "这就解释得通了。",
      "quality": 0.84,
      "tags": [
        "reaction"
      ]
    },
    {
      "source_text": "That is not the point.",
      "target_text": "重点不是这个。",
      "quality": 0.84,
      "tags": [
        "dialogue"
      ]
    },
    {
      "source_text": "Let's not get ahead of ourselves.",
