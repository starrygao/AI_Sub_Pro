      "tags": [
        "subtitle",
        "colloquial"
      ]
    },
    {
      "source_text": "This is between you and me.",
      "target_text": "这是你我之间的事。",
      "quality": 0.84,
      "tags": [
        "subtitle",
        "colloquial"
      ]
    },
    {
      "source_text": "This is bigger than us.",
