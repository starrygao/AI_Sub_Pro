      "quality": 0.84,
      "tags": [
        "dialogue"
      ]
    },
    {
      "source_text": "You did the right thing.",
      "target_text": "你做得对。",
      "quality": 0.84,
      "tags": [
        "encouragement"
      ]
    },
    {
      "source_text": "Don't beat yourself up.",
      "target_text": "别太责怪自己。",
      "quality": 0.84,
      "tags": [
        "encouragement"
      ]
    },
    {
      "source_text": "I'm trying to help.",
