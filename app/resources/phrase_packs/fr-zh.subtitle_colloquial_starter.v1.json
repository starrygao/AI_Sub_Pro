  "quality": 0.82,
  "phrases": [
    {
      "source_text": "Ce n'est pas possible.",
      "target_text": "不会吧。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Dis-moi la vérité.",
      "target_text": "跟我说实话。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ne t'inquiète pas.",
      "target_text": "别担心。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Je m'en occupe.",
      "target_text": "我来处理。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ce ne sont pas tes affaires.",
      "target_text": "这不关你的事。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Laisse tomber.",
      "target_text": "算了吧。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Attends une seconde.",
      "target_text": "等一下。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ça va ?",
      "target_text": "你没事吧？",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ne rends pas ça bizarre.",
      "target_text": "别把气氛搞尴尬。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ne me regarde pas comme ça.",
      "target_text": "别那样看着我。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Je te dois une fière chandelle.",
      "target_text": "我欠你个人情。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ce n'était pas mon intention.",
      "target_text": "我不是故意的。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "On n'a pas le temps.",
      "target_text": "我们没时间了。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Parle moins fort.",
      "target_text": "小声点。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Fais-moi confiance.",
      "target_text": "相信我。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ne me laisse pas ici.",
      "target_text": "别把我丢在这儿。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ça explique beaucoup de choses.",
      "target_text": "这就解释得通了。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ça n'a aucun sens.",
      "target_text": "这说不通。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ne le prends pas personnellement.",
      "target_text": "别往心里去。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "C'était déplacé.",
      "target_text": "那太过分了。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Je viens avec toi.",
      "target_text": "我跟你一起去。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Je ne peux rien promettre.",
      "target_text": "我不能保证。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Tu as raison.",
      "target_text": "你说得对。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Je me suis trompé.",
      "target_text": "我错了。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Je ne suis pas d'humeur.",
      "target_text": "我现在没心情。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "On en reparle plus tard.",
      "target_text": "我们之后再谈。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Je ne veux pas d'ennuis.",
      "target_text": "我不想惹麻烦。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ça reste entre nous.",
      "target_text": "这事只有我们知道。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Je ne l'avais pas vu venir.",
      "target_text": "这我真没想到。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Donne-moi une minute.",
      "target_text": "给我一分钟。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Je ne peux pas continuer comme ça.",
      "target_text": "我不能再这样下去了。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ça ressemble à un piège.",
      "target_text": "听起来像陷阱。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ne commence pas.",
      "target_text": "别又来了。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ne me fais pas regretter.",
      "target_text": "别让我后悔。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "J'essaie d'aider.",
      "target_text": "我是在帮忙。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Tu ne m'écoutes pas.",
      "target_text": "你根本没在听。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Partons d'ici.",
      "target_text": "我们离开这里吧。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Reste avec moi.",
      "target_text": "陪着我。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ne dis rien.",
      "target_text": "什么都别说。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Je gère la situation.",
      "target_text": "我能控制住。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ça change tout.",
      "target_text": "这下情况全变了。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ne compte pas là-dessus.",
      "target_text": "别指望这个。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ce n'est pas si simple.",
      "target_text": "没那么简单。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "On verra bien.",
      "target_text": "到时候再说。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Je n'ai pas le choix.",
      "target_text": "我别无选择。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ne t'en veux pas.",
      "target_text": "别责怪自己。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "On y va étape par étape.",
      "target_text": "一步一步来。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Il n'y a pas de retour en arrière.",
      "target_text": "没有回头路了。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Ce n'est pas terminé.",
      "target_text": "这事还没完。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "Je t'expliquerai plus tard.",
      "target_text": "我之后再解释。",
      "quality": 0.82,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    }
  ]
}
