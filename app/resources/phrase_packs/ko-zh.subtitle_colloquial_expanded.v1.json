  "phrases": [
    {
      "source_text": "믿을 수가 없어.",
      "target_text": "真不敢相信。",
      "quality": 0.83,
      "tags": [
        "subtitle",
        "dialogue",
        "colloquial"
      ]
    },
    {
      "source_text": "다시 말해 봐.",
