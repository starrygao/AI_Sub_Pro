# Optional: move runtime data out of ./data during development.
AI_SUB_PRO_DATA_DIR=

# Optional: bind the headless server to a different host.
AISUBPRO_HOST=127.0.0.1

# Optional: add trusted browser origins for local API access.
# Example: AISUBPRO_CORS_ORIGINS=https://trusted.example,http://app.local
AISUBPRO_CORS_ORIGINS=

# Optional: graceful shutdown timeout in seconds, clamped by the app.
AISUBPRO_GRACEFUL_SHUTDOWN_TIMEOUT=3

# Optional: local MLX Whisper model root for offline/bundled ASR.
AISUBPRO_ASR_MODEL_DIR=
